<!DOCTYPE html>
<html>
<head>
<title>Edit Student</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
body{
  background: linear-gradient(135deg,#eef2ff,#f8fafc);
  color:#0f172a;
}

/* HEADER */
.header{
  position:relative;
  margin-bottom:40px;
}

.page-title{
  text-align:center;
  font-weight:600;
}

/* BACK BUTTON */
.back-btn{
  position:absolute;
  right:0;
  top:0;
}

/* CARD */
.card-ui{
  background:#ffffff;
  border-radius:14px;
  box-shadow:0 10px 30px rgba(0,0,0,0.08);
  padding:30px;
}

/* FORM CENTER */
.form-wrapper{
  max-width:420px;
  margin:0 auto;
}

/* INPUT */
.form-control{
  border-radius:8px;
  padding:10px;
}

/* BUTTON */
.btn{
  border-radius:8px;
  font-weight:500;
}
</style>
</head>

<body class="p-4">

<div class="container">

<!-- HEADER -->
<div class="header">
  <h3 class="page-title">Edit Student</h3>

  <a href="/" class="btn btn-outline-dark btn-sm back-btn">
    <i class="bi bi-arrow-left"></i> Back
  </a>
</div>

<!-- FORM -->
<div class="form-wrapper">
  <div class="card-ui">

    <form id="form">
      <input name="name" value="<%= student.name %>" class="form-control mb-3">
      <input name="phone" value="<%= student.phone %>" class="form-control mb-3">
      <input name="email" value="<%= student.email %>" class="form-control mb-3">

      <button class="btn btn-primary w-100">Update</button>
    </form>

  </div>
</div>

</div>

<script>
const form = document.getElementById("form");

form.onsubmit = async e => {
  e.preventDefault();

  const res = await fetch(`/students/<%= student._id %>`,{
    method:"PUT",
    headers:{"Content-Type":"application/json"},
    body:JSON.stringify({
      name:form.name.value,
      phone:form.phone.value,
      email:form.email.value
    })
  });

  const d = await res.json();

  if(d.success){
    window.location.href="/?msg=updated";
  }else{
    alert(d.message);
  }
}
</script>

</body>
</html>