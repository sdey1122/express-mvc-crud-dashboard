<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Dashboard</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet">

<style>
body{
  background: linear-gradient(135deg,#eef2ff,#f8fafc);
  color:#0f172a;
}

.card-ui{
  background:#ffffff;
  border-radius:14px;
  box-shadow:0 8px 25px rgba(0,0,0,0.08);
  padding:20px;
}

.table{
  color:#0f172a;
}

.table th{
  background:#f1f5f9;
}

.top-bar{
  display:flex;
  justify-content:space-between;
  align-items:center;
  margin-bottom:20px;
}

.page-title{
  display: flex;
  justify-content: center;
  align-items: center;
  font-weight:600;
}

.btn{
  border-radius:8px;
}
</style>
</head>

<body class="p-4">
   
<div class="container">
<div>
     <h2 class="page-title">Dashboard</h2>
</div>
<div class="top-bar position-relative">

<a href="/add" class="btn btn-primary btn-sm ms-2">
<i class="bi bi-plus"></i> Add Student
</a>

<a href="/restore" class="btn btn-outline-primary btn-sm me-2">
<i class="bi bi-arrow-counterclockwise"></i> Restore
</a>
</div>

<div class="card-ui p-3">
<table class="table text-center align-middle">
<thead>
<tr><th>ID</th><th>Sl. No.</th><th>Name</th><th>Phone</th><th>Email</th><th>Action</th></tr>
</thead>

<tbody>
<% students.forEach((p,i)=>{ %>
<tr>
<td>****<%= p._id.toString().slice(-4) %></td>
<td><%= i+1 %></td>
<td><%= p.name %></td>
<td><%= p.phone %></td>
<td><%= p.email %></td>
<td>

<a href="/edit/<%= p._id %>" class="btn btn-outline-dark btn-sm">
<i class="bi bi-pencil"></i>
</a>

<button class="btn btn-outline-danger btn-sm" onclick="deleteItem('<%= p._id %>')">
<i class="bi bi-trash"></i>
</button>

</td>
</tr>
<% }) %>
</tbody>
</table>
</div>
</div>

<!-- TOAST -->
<div class="position-fixed top-0 end-0 p-3">
<div id="toast" class="toast text-bg-success">
<div class="toast-body" id="msg"></div>
</div>
</div>

<!-- MODAL -->
<div class="modal fade" id="modal">
<div class="modal-dialog modal-dialog-centered">
<div class="modal-content bg-dark text-white">
<div class="modal-body" id="modalText"></div>
<div class="modal-footer">
<button class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
<button class="btn btn-danger" id="confirmBtn">Confirm</button>
</div>
</div>
</div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

<script>
// TOAST
function showToast(message){
const toastEl = document.getElementById("toast");
document.getElementById("msg").innerText = message;
new bootstrap.Toast(toastEl,{delay:1200}).show();
}

// SHOW AFTER REDIRECT
const params = new URLSearchParams(window.location.search);
const msg = params.get("msg");

if(msg==="added") showToast("Student added successfully");
if(msg==="updated") showToast("Student updated successfully");
if(msg==="deleted") showToast("Student deleted successfully");

// MODAL
let modal = new bootstrap.Modal(document.getElementById("modal"));
let action = null;

function confirmAction(text, cb){
document.getElementById("modalText").innerText = text;
action = cb;
modal.show();
}

document.getElementById("confirmBtn").onclick = () => {
modal.hide();
if(action) action();
};

// DELETE
function deleteItem(id){
confirmAction("Do you want to delete this record?", async ()=>{
const res = await fetch(`/students/delete/${id}?_method=PATCH`, { method:"POST" });
const d = await res.json();

if(d.success){
window.location.href="/?msg=deleted";
}else alert(d.message);
});
}
</script>

</body>
</html>